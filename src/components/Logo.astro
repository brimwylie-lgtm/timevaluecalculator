---
// AfterWage logo — the bracket direction.
// Variants:
//   full     — masthead lockup with tagline (homepage footer, large displays)
//   compact  — [After] Wage inline, no tagline (headers, subpage tops)
//   mark     — [a] bracket only (favicon, tight spaces, watermarks)
//
// Props:
//   variant:  'full' | 'compact' | 'mark'   default 'compact'
//   theme:    'light' | 'dark'               default 'light'
//              light = ink on cream; dark = cream on ink
//   size:     number (height in px)          default depends on variant
//   className: optional CSS classes

export interface Props {
  variant?: 'full' | 'compact' | 'mark';
  theme?: 'light' | 'dark';
  size?: number;
  className?: string;
}

const {
  variant = 'compact',
  theme = 'light',
  size,
  className = '',
} = Astro.props;

const ink = theme === 'light' ? '#1A1A1A' : '#F5F1E8';
const accent = theme === 'light' ? '#8B2E1F' : '#D4A87E';
const mute = theme === 'light' ? '#2C2C2C' : '#B8895C';

const defaultSizes = { full: 140, compact: 40, mark: 32 };
const h = size ?? defaultSizes[variant];
---

{variant === 'full' && (
  <svg
    viewBox="0 0 800 280"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: auto; display: block;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    {/* Masthead rules top/bottom */}
    <line x1="100" y1="40" x2="700" y2="40" stroke={ink} stroke-width="1" />

    {/* Top eyebrow */}
    <text x="400" y="30" font-family="ui-monospace, 'JetBrains Mono', monospace" font-size="12" font-weight="500" letter-spacing="5" text-anchor="middle" fill={mute}>A CALCULATOR / VOL. 01</text>

    {/* Main lockup - single text element with tspans flows naturally */}
    <text x="400" y="150" font-family="Fraunces, Georgia, serif" font-size="84" font-weight="300" text-anchor="middle">
      <tspan font-family="ui-monospace, 'JetBrains Mono', monospace" font-weight="400" font-size="100" fill={ink}>[</tspan>
      <tspan fill={accent} dx="6">After</tspan>
      <tspan font-family="ui-monospace, 'JetBrains Mono', monospace" font-weight="400" font-size="100" fill={ink} dx="6">]</tspan>
      <tspan font-style="italic" fill={ink} dx="10">Wage</tspan>
    </text>

    {/* Tagline */}
    <text x="400" y="210" font-family="Fraunces, Georgia, serif" font-style="italic" font-weight="300" font-size="26" text-anchor="middle" fill={mute}>what's my time worth?</text>

    {/* Bottom rule */}
    <line x1="100" y1="240" x2="700" y2="240" stroke={ink} stroke-width="1" />
  </svg>
)}

{variant === 'compact' && (
  <svg
    viewBox="0 0 260 48"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: auto; display: block;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    <text x="0" y="34" font-family="Fraunces, Georgia, serif" font-size="26" font-weight="300">
      <tspan font-family="ui-monospace, 'JetBrains Mono', monospace" font-weight="400" font-size="30" fill={ink}>[</tspan>
      <tspan fill={accent} dx="2">After</tspan>
      <tspan font-family="ui-monospace, 'JetBrains Mono', monospace" font-weight="400" font-size="30" fill={ink} dx="2">]</tspan>
      <tspan font-style="italic" fill={ink} dx="4">Wage</tspan>
    </text>
  </svg>
)}

{variant === 'mark' && (
  <svg
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: ${h}px; display: block;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    <text x="32" y="44" font-family="ui-monospace, 'JetBrains Mono', monospace" font-weight="500" font-size="36" text-anchor="middle" fill={ink}>[<tspan fill={accent}>a</tspan>]</text>
  </svg>
)}
