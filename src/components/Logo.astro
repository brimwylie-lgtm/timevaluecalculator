---
// AfterWage logo — the bracket direction.
// Variants:
//   full     — masthead lockup with tagline (homepage footer, OG image)
//   compact  — [After] Wage inline, no tagline (subpage headers)
//   mark     — [a] bracket only (favicon, tight spaces, watermarks)
//
// Props:
//   variant:  'full' | 'compact' | 'mark'   default 'compact'
//   theme:    'light' | 'dark'               default 'light'
//              light = ink on cream; dark = cream on ink
//   size:     number (height in px)          default depends on variant

export interface Props {
  variant?: 'full' | 'compact' | 'mark';
  theme?: 'light' | 'dark';
  size?: number;
  className?: string;
}

const {
  variant = 'compact',
  theme = 'light',
  size,
  className = '',
} = Astro.props;

// Theme colors
const ink = theme === 'light' ? '#1A1A1A' : '#F5F1E8';
const accent = theme === 'light' ? '#8B2E1F' : '#D4A87E';
const mute = theme === 'light' ? '#2C2C2C' : '#EDE7D6';

const defaultSizes = { full: 120, compact: 36, mark: 32 };
const h = size ?? defaultSizes[variant];
---

{variant === 'full' && (
  <svg
    viewBox="0 0 600 220"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: auto;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    <g transform="translate(300, 110)">
      <text x="-130" y="0" font-family="'JetBrains Mono', monospace" font-weight="400" font-size="78" text-anchor="end" fill={ink}>[</text>
      <text x="-5" y="0" font-family="Fraunces, Georgia, serif" font-weight="300" font-size="62" text-anchor="middle" fill={accent} style="font-variation-settings: 'SOFT' 50;">After</text>
      <text x="110" y="0" font-family="'JetBrains Mono', monospace" font-weight="400" font-size="78" text-anchor="start" fill={ink}>]</text>
      <text x="210" y="0" font-family="Fraunces, Georgia, serif" font-weight="300" font-style="italic" font-size="62" text-anchor="start" fill={ink} style="font-variation-settings: 'SOFT' 70;">Wage</text>
    </g>
    <text x="300" y="170" font-family="Fraunces, Georgia, serif" font-style="italic" font-weight="300" font-size="20" text-anchor="middle" fill={mute} style="font-variation-settings: 'SOFT' 60;">what's my time worth?</text>
  </svg>
)}

{variant === 'compact' && (
  <svg
    viewBox="0 0 220 48"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: auto;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    <text x="6" y="32" font-family="'JetBrains Mono', monospace" font-weight="400" font-size="22" fill={ink}>[</text>
    <text x="20" y="32" font-family="Fraunces, Georgia, serif" font-weight="300" font-size="22" fill={accent} style="font-variation-settings: 'SOFT' 50;">After</text>
    <text x="78" y="32" font-family="'JetBrains Mono', monospace" font-weight="400" font-size="22" fill={ink}>]</text>
    <text x="96" y="32" font-family="Fraunces, Georgia, serif" font-weight="300" font-style="italic" font-size="22" fill={ink} style="font-variation-settings: 'SOFT' 70;">Wage</text>
  </svg>
)}

{variant === 'mark' && (
  <svg
    viewBox="0 0 64 64"
    xmlns="http://www.w3.org/2000/svg"
    style={`height: ${h}px; width: ${h}px;`}
    class={className}
    aria-label="AfterWage"
    role="img"
  >
    <text x="32" y="44" font-family="'JetBrains Mono', monospace" font-weight="500" font-size="36" text-anchor="middle" fill={ink}>[<tspan fill={accent}>a</tspan>]</text>
  </svg>
)}
