---
import Logo from './Logo.astro';
---

<footer class="relative z-10 mt-24 border-t border-ink/10 py-12">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
      <a href="/" class="inline-flex items-center hover:opacity-70 transition-opacity">
        <Logo variant="compact" size={28} />
      </a>
      <nav class="flex gap-5 font-mono text-xs uppercase tracking-widest flex-wrap">
        <a href="/" class="hover:text-blood">Home</a>
        <a href="/methodology" class="hover:text-blood">Methodology</a>
        <a href="/about" class="hover:text-blood">About</a>
        <a href="/contact" class="hover:text-blood">Contact</a>
        <a href="/privacy" class="hover:text-blood">Privacy</a>
        <a href="/terms" class="hover:text-blood">Terms</a>
      </nav>
    </div>

    <div class="mt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="font-mono text-xs uppercase tracking-widest text-mute">
        &copy; 2026 AfterWage. All rights reserved.
      </p>
      <nav class="flex gap-5 font-mono text-xs uppercase tracking-widest" aria-label="Social media">
        <a href="https://www.instagram.com/afterwagecalc/" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-blood">Instagram</a>
        <a href="https://www.threads.com/@afterwagecalc" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-blood">Threads</a>
        <a href="https://www.tiktok.com/@afterwage" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-blood">TikTok</a>
        <a href="https://www.youtube.com/@AfterWage" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-blood">YouTube</a>
        <a href="https://twitter.com/afterwage" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-blood">X</a>
      </nav>
    </div>
  </div>
</footer>
